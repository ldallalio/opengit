{
  "name": "opengit",
  "version": "0.2.0",
  "private": true,
  "description": "A local-first cross-platform Git desktop client.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/desktop",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/desktop run tauri:dev",
    "build": "npm --workspace apps/desktop run build",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "test": "npm run test:js && npm run test:rust",
    "test:js": "npm --workspaces --if-present run test",
    "test:rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "check": "npm run typecheck && npm run build && npm run test",
    "tauri:dev": "npm --workspace apps/desktop run tauri:dev",
    "tauri:build": "npm --workspace apps/desktop run tauri:build",
    "tauri:build:mac-app": "npm --workspace apps/desktop run tauri:build:mac-app"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
