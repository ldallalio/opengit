{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenGit",
  "version": "0.2.3",
  "identifier": "dev.opengit.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenGit",
        "width": 1360,
        "height": 860,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFNzNEMUY2REIwQzA1QzcKUldUSEJRemI5dEZ6cm5HSVFJdFVrbXlJMm44emsvS1VuWFhzUnlhZlVuKzRqcm0zbDFUOVEwQkoK",
      "endpoints": [
        "https://github.com/ldallalio/opengit/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
