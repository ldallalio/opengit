{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability for OpenGit.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://**" }]
    }
  ]
}
